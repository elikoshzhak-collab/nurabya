<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Для Нурабии ❤️</title>
<style>
body{
  margin:0;
  font-family:Arial, sans-serif;
  text-align:center;
  overflow-x:hidden;
  background: linear-gradient(270deg,#ffd6ec,#ffecb3,#c0ffc8);
  background-size: 1000% 1000%;
  animation: rainbow 25s ease infinite;
}

@keyframes rainbow{
  0%{background-position:0% 50%;}
  50%{background-position:100% 50%;}
  100%{background-position:0% 50%;}
}

#passwordScreen{
  position:fixed;
  width:100%;
  height:100%;
  background:#fff0f5;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
}

#passwordScreen input{
  padding:10px;
  font-size:16px;
  border-radius:8px;
  border:2px solid #ff6f91;
  margin-bottom:15px;
}

#passwordScreen button{
  padding:10px 20px;
  font-size:16px;
  border:none;
  border-radius:8px;
  background:#ff6f91;
  color:white;
  cursor:pointer;
}

.container{
  display:none;
  padding:20px;
}

h1{
  font-size:44px;
  color:#ff6f91;
  text-shadow:0 0 8px #ff6f91,0 0 15px #ffb6c1;
  animation: glow 3s ease-in-out infinite alternate;
}

@keyframes glow{
  0%{text-shadow:0 0 3px #ff6f91;}
  100%{text-shadow:0 0 15px #ffb6c1;}
}

.photo img{
  width:280px;
  border-radius:20px;
  box-shadow:0 10px 25px rgba(0,0,0,0.2);
  margin-top:20px;
  transition: transform 0.4s, box-shadow 0.4s;
}
.photo img:hover{
  transform: scale(1.08);
  box-shadow:0 15px 35px rgba(0,0,0,0.3);
}

button{
  margin-top:20px;
  padding:12px 28px;
  font-size:16px;
  border:none;
  border-radius:12px;
  background:#ff6f91;
  color:white;
  cursor:pointer;
}

#surprise{
  display:none;
  font-size:28px;
  margin-top:15px;
  color:#ff6f91;
  font-weight:bold;
  animation: pulse 2s infinite;
}

#letter{
  display:none;
  margin-top:15px;
  font-size:20px;
  max-width:600px;
  margin-left:auto;
  margin-right:auto;
  line-height:1.5;
  color:#333;
  background: rgba(255,255,255,0.85);
  padding:12px;
  border-radius:12px;
  box-shadow:0 6px 15px rgba(0,0,0,0.15);
}

#love{
  margin-top:25px;
  font-size:44px;
  color:#ff6f91;
  font-weight:bold;
  animation:pulse 2s infinite;
}

@keyframes pulse{
  0%{transform:scale(1);}
  50%{transform:scale(1.15);}
  100%{transform:scale(1);}
}

.falling{
  position:fixed;
  top:-10px;
  font-size:20px;
  animation:fall linear infinite;
  pointer-events:none;
}
@keyframes fall{
  0%{transform:translateY(-10px);}
  100%{transform:translateY(100vh);}
}
</style>
</head>
<body>

<div id="passwordScreen">
  <h2>Введите пароль</h2>
  <input type="password" id="passwordInput" placeholder="Пароль">
  <button onclick="checkPassword()">Войти</button>
  <p id="errorMsg" style="color:red;display:none;">Неверный пароль!</p>
</div>

<div class="container" id="content">

  <h1>С 8 Марта, Нурабия 🌸</h1>

  <p>
    Пусть твой день будет светлым и радостным ✨<br>
    Желаю счастья, улыбок и любви ❤️
  </p>

  <div class="photo">
    <img src="nura-photo.jpg">
  </div>

  <button onclick="showSurprise()">Нажми сюрприз 🎁</button>

  <div id="surprise">
    Ты очень милая и особенная!
  </div>

  <button onclick="showLetter()">Открыть письмо 💌</button>

  <div id="letter">
    Дорогая Нурабия,<br>
    Желаю радости и тепла каждый день ✨<br>
    🌸💖✨❤️
  </div>

  <div id="love">
    I ❤️ Nurabiya
  </div>

  <audio autoplay loop>
    <source src="nura-love.mp3" type="audio/mpeg">
  </audio>

</div>

<script>
function checkPassword(){
  const password="nuraqueen"; // пароль для входа
  const input=document.getElementById("passwordInput").value;
  if(input===password){
    document.getElementById("passwordScreen").style.display="none";
    document.getElementById("content").style.display="block";
  } else {
    document.getElementById("errorMsg").style.display="block";
  }
}

function showSurprise(){
  document.getElementById("surprise").style.display="block";
}

function showLetter(){
  document.getElementById("letter").style.display="block";
}

// Падающие эмодзи — мягкий дождь, не слишком много
function createFallingEmojis(){
  const emojis=["❤️","🌸","✨","💖"];
  for(let i=0;i<3;i++){
    const e=document.createElement("div");
    e.classList.add("falling");
    e.innerHTML=emojis[Math.floor(Math.random()*emojis.length)];
    e.style.left=Math.random()*100+"vw";
    e.style.animationDuration=(4+Math.random()*4)+"s";
    e.style.fontSize=(16+Math.random()*25)+"px";
    document.body.appendChild(e);
    setTimeout(()=>{e.remove();},9000);
  }
}

setInterval(createFallingEmojis,400);
</script>

</body>
</html>
